{
    "name": "ai-commenter",
    "displayName": "AI Commenter",
    "publisher": "aayushadeshara",
    "description": "AI-powered git commit messages and prompt optimization for coding agents.",
    "version": "1.1.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/aayushadeshara/ai-commenter"
    },
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "AI",
        "SCM Providers",
        "Other"
    ],
    "keywords": [
        "ai",
        "git",
        "commit",
        "mistral",
        "branch",
        "productivity",
        "prompt",
        "optimizer"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "aiCommenter.generate",
                "title": "AI: Generate Commit Message"
            },
            {
                "command": "aiCommenter.optimizePrompt",
                "title": "AI: Optimize Selected Prompt"
            }
        ],
        "keybindings": [
            {
                "command": "aiCommenter.generate",
                "key": "ctrl+shift+c",
                "mac": "cmd+shift+c"
            },
            {
                "command": "aiCommenter.optimizePrompt",
                "key": "ctrl+shift+p",
                "mac": "cmd+shift+p"
            }
        ],
        "configuration": {
            "title": "AI Commenter",
            "properties": {
                "aiCommenter.mistralApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Your Mistral AI API Key to generate commit messages."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "npm version patch --no-git-tag-version && npx @vscode/vsce package"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.1.3"
    }
}
